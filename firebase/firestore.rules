rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // users/{uid}: 自分のドキュメントのみ read/write 可
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // memory_notes/{noteId}: Phase 5 — personal note CRUD
    // read/update: ownerId == uid OR uid is in members map
    // create: 認証済み & ownerId == 自分
    // delete: ownerId のみ（Owner のみ削除可）
    match /memory_notes/{noteId} {
      allow read: if request.auth != null
        && (resource.data.ownerId == request.auth.uid
            || (resource.data.members != null
                && request.auth.uid in resource.data.members));

      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid;

      allow update: if request.auth != null
        && (resource.data.ownerId == request.auth.uid
            || (resource.data.members != null
                && request.auth.uid in resource.data.members));

      allow delete: if request.auth != null
        && resource.data.ownerId == request.auth.uid;
    }

    // その他のコレクションは認証済みでも原則拒否
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
