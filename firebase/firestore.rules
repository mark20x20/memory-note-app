rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── users/{uid} ──────────────────────────────────────────────────────────
    // Phase 11: 認証済みユーザーなら誰でも read 可（メンバー表示のため）。
    // write は自分自身のドキュメントのみ。
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── memory_notes/{noteId} ────────────────────────────────────────────────
    // read:   owner または members に含まれるユーザー
    // create: 認証済み & ownerId == 自分
    // update: owner または editor（Phase 11: members はクライアントから変更不可）
    // delete: owner のみ
    match /memory_notes/{noteId} {
      allow read: if request.auth != null
        && (resource.data.ownerId == request.auth.uid
            || (resource.data.members != null
                && request.auth.uid in resource.data.members));

      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid;

      // Phase 11: update 条件を強化
      // - owner または editor のみ
      // - ownerId は変更不可
      // - members はクライアントから直接変更不可（Cloud Functions Admin SDK 経由のみ）
      allow update: if request.auth != null
        && (resource.data.ownerId == request.auth.uid
            || (resource.data.members != null
                && request.auth.uid in resource.data.members
                && resource.data.members[request.auth.uid] in ['owner', 'editor']))
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.members == resource.data.members;

      allow delete: if request.auth != null
        && resource.data.ownerId == request.auth.uid;

      // ── memory_notes/{noteId}/photos/{photoId} ──────────────────────────
      // Phase 11: 権限を role ベースに更新
      // read:   note members（owner / editor / viewer）
      // create: owner または editor（ownerId == 自分）
      // update: owner または editor
      // delete: owner のみ
      match /photos/{photoId} {
        // read: note の members に含まれるユーザー（get() で親 doc を参照）
        allow read: if request.auth != null
          && (resource.data.ownerId == request.auth.uid
              || (get(/databases/$(database)/documents/memory_notes/$(noteId)).data.members != null
                  && request.auth.uid in get(/databases/$(database)/documents/memory_notes/$(noteId)).data.members));

        // create: owner または editor のみ（ownerId == 自分）
        allow create: if request.auth != null
          && request.resource.data.ownerId == request.auth.uid
          && (get(/databases/$(database)/documents/memory_notes/$(noteId)).data.members != null
              && request.auth.uid in get(/databases/$(database)/documents/memory_notes/$(noteId)).data.members
              && get(/databases/$(database)/documents/memory_notes/$(noteId)).data.members[request.auth.uid] in ['owner', 'editor']);

        // update: owner または editor
        allow update: if request.auth != null
          && (resource.data.ownerId == request.auth.uid
              || (get(/databases/$(database)/documents/memory_notes/$(noteId)).data.members != null
                  && request.auth.uid in get(/databases/$(database)/documents/memory_notes/$(noteId)).data.members
                  && get(/databases/$(database)/documents/memory_notes/$(noteId)).data.members[request.auth.uid] in ['owner', 'editor']));

        // delete: owner のみ（Storage cleanup 時は admin SDK から実行するが、
        // クライアント削除も owner のみ許可）
        allow delete: if request.auth != null
          && get(/databases/$(database)/documents/memory_notes/$(noteId)).data.ownerId == request.auth.uid;
      }

      // ── memory_notes/{noteId}/place_groups/{placeGroupId} ───────────────
      // Phase 12.5B: Place Intelligence — PlaceGroup / PlaceCandidate Rules
      //
      // place_groups:
      //   read:   members（owner / editor / viewer）
      //   create: owner または editor
      //   update: owner または editor
      //   delete: owner のみ
      //
      // candidates（サブコレクション）:
      //   read:   owner または editor のみ（viewer は非表示 — プライバシーポリシー準拠）
      //   create: owner または editor
      //   update: owner または editor
      //   delete: owner のみ
      //
      // viewer に candidates を非表示にする理由:
      //   候補リストには座標・住所・外部 API の rating 等が含まれる。
      //   viewer は確定場所名（PlaceGroupDoc.label）のみ参照できれば十分。
      //   07_privacy_security_cost_policy.md の viewer 表示方針と整合する。
      match /place_groups/{placeGroupId} {
        // read: note の members（viewer を含む）
        allow read: if request.auth != null
          && (get(/databases/$(database)/documents/memory_notes/$(noteId)).data.ownerId == request.auth.uid
              || (get(/databases/$(database)/documents/memory_notes/$(noteId)).data.members != null
                  && request.auth.uid in get(/databases/$(database)/documents/memory_notes/$(noteId)).data.members));

        // create: owner または editor のみ
        allow create: if request.auth != null
          && (get(/databases/$(database)/documents/memory_notes/$(noteId)).data.members != null
              && request.auth.uid in get(/databases/$(database)/documents/memory_notes/$(noteId)).data.members
              && get(/databases/$(database)/documents/memory_notes/$(noteId)).data.members[request.auth.uid] in ['owner', 'editor']);

        // update: owner または editor のみ
        allow update: if request.auth != null
          && (get(/databases/$(database)/documents/memory_notes/$(noteId)).data.members != null
              && request.auth.uid in get(/databases/$(database)/documents/memory_notes/$(noteId)).data.members
              && get(/databases/$(database)/documents/memory_notes/$(noteId)).data.members[request.auth.uid] in ['owner', 'editor']);

        // delete: owner のみ
        allow delete: if request.auth != null
          && get(/databases/$(database)/documents/memory_notes/$(noteId)).data.ownerId == request.auth.uid;

        // candidates サブコレクション: owner / editor のみ read 可
        match /candidates/{candidateId} {
          // read: owner または editor のみ（viewer は不可）
          allow read: if request.auth != null
            && (get(/databases/$(database)/documents/memory_notes/$(noteId)).data.members != null
                && request.auth.uid in get(/databases/$(database)/documents/memory_notes/$(noteId)).data.members
                && get(/databases/$(database)/documents/memory_notes/$(noteId)).data.members[request.auth.uid] in ['owner', 'editor']);

          // create: owner または editor のみ（主に Cloud Functions Admin SDK から書き込む）
          allow create: if request.auth != null
            && (get(/databases/$(database)/documents/memory_notes/$(noteId)).data.members != null
                && request.auth.uid in get(/databases/$(database)/documents/memory_notes/$(noteId)).data.members
                && get(/databases/$(database)/documents/memory_notes/$(noteId)).data.members[request.auth.uid] in ['owner', 'editor']);

          // update: owner または editor のみ
          allow update: if request.auth != null
            && (get(/databases/$(database)/documents/memory_notes/$(noteId)).data.members != null
                && request.auth.uid in get(/databases/$(database)/documents/memory_notes/$(noteId)).data.members
                && get(/databases/$(database)/documents/memory_notes/$(noteId)).data.members[request.auth.uid] in ['owner', 'editor']);

          // delete: owner のみ
          allow delete: if request.auth != null
            && get(/databases/$(database)/documents/memory_notes/$(noteId)).data.ownerId == request.auth.uid;
        }
      }
    }

    // その他のコレクションは認証済みでも原則拒否
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
