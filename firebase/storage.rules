rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── ノート写真 ────────────────────────────────────────────────────────────
    // パス: users/{uid}/memory_notes/{noteId}/photos/{fileName}
    // uid はノート所有者の UID（写真は常にノートオーナーの Storage パスに保存）
    //
    // Phase 11 権限:
    // - create/update: owner のみ（uid == request.auth.uid, 画像形式, 10MB 以下）
    // - delete:        owner のみ
    // - read:          ノートの members に含まれるユーザー（firestore.get で確認）
    //
    // editor は現時点では写真アップロード不可（Phase 11 スコープ外）。
    // Phase 11 以降でアップロードパスを共通化して editor 対応を追加予定。
    match /users/{uid}/memory_notes/{noteId}/photos/{fileName} {
      allow create, update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.contentType.matches('image/.*')
        && request.resource.size < 10 * 1024 * 1024;

      // Phase 10: 削除は request.resource が null になるため別途許可
      allow delete: if request.auth != null
        && request.auth.uid == uid;

      // Phase 11: ノート members に含まれるユーザーが read 可
      // - 自分が owner（uid == request.auth.uid）の場合は常に read 可
      // - それ以外は Firestore のノート members マップを確認する
      allow read: if request.auth != null
        && (request.auth.uid == uid
            || firestore.get(
                /databases/(default)/documents/memory_notes/$(noteId)
               ).data.members[request.auth.uid] != null);
    }

    // その他のパスは原則拒否
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
