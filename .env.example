# Firebase Web SDK configuration
# These values are public (safe to expose in client-side code)
# Get these from Firebase Console → Project Settings → Your apps → Web app
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Cloud Functions region (default: asia-northeast1)
EXPO_PUBLIC_FIREBASE_FUNCTIONS_REGION=asia-northeast1

# Firebase Emulator settings
# Set USE_FIREBASE_EMULATOR=true to connect to local emulators
EXPO_PUBLIC_USE_FIREBASE_EMULATOR=false
# Android emulator: 10.0.2.2 / iOS Simulator / real device: PC's LAN IP
EXPO_PUBLIC_FIREBASE_EMULATOR_HOST=localhost

# DO NOT add OpenAI API keys or Firebase Admin SDK credentials here
