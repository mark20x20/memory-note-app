{
  "expo": {
    "name": "Memory Note",
    "slug": "memory-note-app",
    "version": "1.0.0",
    "scheme": "memorynote",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.memorynote.app"
    },
    "android": {
      "package": "com.memorynote.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "思い出ノートを作成するために、写真ライブラリへのアクセスを使用します。"
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "共有カード画像を写真ライブラリに保存するために使用します。",
          "savePhotosPermission": "共有カード画像を写真ライブラリに保存するために使用します。",
          "isAccessMediaLocationEnabled": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
